# Vercel Deployment Environment Variables
# Copy this file to .env.production for Vercel deployment

# Backend API URL (Railway, Render, or your own server)
VITE_API_URL=https://your-backend.railway.app
VITE_SOCKET_URL=https://your-backend.railway.app

# Hand tracking server (optional - only needed if using camera mode)
VITE_HAND_TRACKING_URL=http://localhost:5001

# Google OAuth Client ID (get from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
