# Server Environment Variables
# Copy this file to .env for production deployment

PORT=5002
NODE_ENV=production

# MongoDB Atlas Connection String
# Get free at: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/aeroscript

# JWT Secret (generate a strong random string for production)
JWT_SECRET=replace-with-a-very-long-random-string

# CORS Allowed Origins (your Vercel frontend URL)
CORS_ORIGINS=https://your-app.vercel.app

